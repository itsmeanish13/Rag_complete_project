# =============================================================
#  .gitignore  —  Python · FastAPI · Docker · Jupyter · Node
#  Copy this file into the root of any project.
#  Lines starting with # are comments — Git ignores them.
# =============================================================


# =============================================================
# SECRETS & ENVIRONMENT VARIABLES
# The most important section — never commit real keys or tokens
# =============================================================
.env
.env.*
!.env.example          # allow the example template (no real values)
*.pem
*.key
secrets/
credentials.json


# =============================================================
# PYTHON
# =============================================================

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
venv.bak/

# Byte-compiled / cached files Python creates automatically
__pycache__/
*.py[cod]              # .pyc .pyo .pyd
*.pyo
*.pyd
.Python

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
nosetests.xml
test-results/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Profiling
*.prof

# PyInstaller
*.manifest
*.spec


# =============================================================
# JUPYTER NOTEBOOK
# =============================================================

# Checkpoint folders created when you save a notebook
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Auto-generated by nbconvert
*.nbconvert.ipynb


# =============================================================
# ANACONDA / CONDA
# =============================================================
.conda/
conda-meta/
pkgs/
envs/

# Conda environment export — keep the yml, not the lock
# (uncomment next line if you don't want to commit environment.yml)
# environment.yml


# =============================================================
# FASTAPI / UVICORN
# =============================================================

# Upload folders (files users upload at runtime)
uploads/
media/
static/uploads/

# Log files
*.log
logs/
log/


# =============================================================
# DOCKER
# =============================================================

# Exported image tarballs
*.tar
*.tar.gz

# Override files for local dev (keep the base compose file)
docker-compose.override.yml


# =============================================================
# NODE / JAVASCRIPT  (if you have any frontend tooling)
# =============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
.npm/
.yarn/


# =============================================================
# OPERATING SYSTEM FILES
# =============================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*
.nfs*


# =============================================================
# EDITORS & IDES
# =============================================================

# VS Code
.vscode/
!.vscode/extensions.json   # allow recommended extensions list

# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.\#*

# Spyder
.spyderproject.cfg
.spyproject/

# Rope (Python refactoring)
.ropeproject/


# =============================================================
# MISC PROJECT FILES
# =============================================================

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej

# Compiled files
*.com
*.class
*.dll
*.exe
*.o
*.so

# Database files (local dev databases)
*.db
*.sqlite
*.sqlite3

# Compressed archives
*.zip
*.rar
*.7z

# PDF outputs (if generated, not source)
# Uncomment if you generate PDFs at runtime:
# *.pdf